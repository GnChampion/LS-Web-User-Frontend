# Copy this file to `.env` (which is gitignored) and fill in the values.
# Build-time Vite env vars (must be present when you run `npm run build` /
# `npm run deploy` locally or in CI, since Firebase Hosting builds the bundle).

# --- Firebase web client config ---
# From Firebase console > Project settings > Your apps > Web app.
# (These are the PUBLIC web config — NOT the Admin SDK service-account JSON.)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=land-scanner-webapp
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Auth wall. Set to "true" once the Firebase web config + a sign-in method
# (email/password or Google) are enabled in the console.
VITE_REQUIRE_AUTH=false

# --- Backend (Render) URLs the frontend calls ---
VITE_BACKEND_URL=https://ls-pull-push-backend.onrender.com
