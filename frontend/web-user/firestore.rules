rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // DEV MODE (active): open access so the prototype works before Firebase
    // Auth is configured. INSECURE — do NOT keep this for production.
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if true;
    }

    // -------------------------------------------------------------------------
    // PRODUCTION RULES: uncomment the block below and delete the DEV MODE block
    // above once Firebase Auth (email/password or Google) is enabled.
    // -------------------------------------------------------------------------
    // match /users/{userId} {
    //   allow read, write: if request.auth != null && request.auth.uid == userId;
    // }
    // match /savedZones/{zoneId} {
    //   allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
    //   allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    // }
    // match /analyses/{analysisId} {
    //   allow read: if true;
    //   allow write: if request.auth != null;
    // }
  }
}
